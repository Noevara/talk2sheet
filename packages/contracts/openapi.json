            "title": "Conversation Id"
          },
          "clarification_resolution": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ClarificationResolution"
              },
              {
                "type": "null"
              }
            ]
          },
          "followup_action": {
            "anyOf": [
              {
                "type": "string",
                "const": "continue_next_step"
              },
              {
                "type": "null"
              }
            ],
            "title": "Followup Action"
          }
        },
        "type": "object",
        "required": [
          "file_id",
          "chat_text"
        ],
        "title": "SpreadsheetChatRequest"
      },
      "UploadedFileResponse": {
        "properties": {
          "file_id": {
            "type": "string",
            "title": "File Id"
          },
          "file_name": {
            "type": "string",
            "title": "File Name"
          },
          "file_type": {
            "type": "string",
            "title": "File Type"
          },
          "sheets": {
            "items": {
              "$ref": "#/components/schemas/SheetDescriptor"
            },
            "type": "array",
            "title": "Sheets"
          }
        },
        "type": "object",
        "required": [
          "file_id",
          "file_name",
          "file_type"
        ],
        "title": "UploadedFileResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}
