{
  "openapi": "3.1.0",
  "info": {
    "title": "Talk2Sheet API",
    "version": "0.1.0"
  },
  "paths": {
    "/api/health": {
      "get": {
        "tags": [
          "system"
        ],
        "summary": "Health",
        "operationId": "health_api_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/files/upload": {
      "post": {
        "tags": [
          "files"
        ],
        "summary": "Upload File",
        "operationId": "upload_file_api_files_upload_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_upload_file_api_files_upload_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadedFileResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/files/{file_id}/sheets": {
      "get": {
        "tags": [
          "files"
        ],
        "summary": "List Sheets",
        "operationId": "list_sheets_api_files__file_id__sheets_get",
        "parameters": [
          {
            "name": "file_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "File Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadedFileResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/files/{file_id}/preview": {
      "get": {
        "tags": [
          "files"
        ],
        "summary": "Get Preview",
        "operationId": "get_preview_api_files__file_id__preview_get",
        "parameters": [
          {
            "name": "file_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "File Id"
            }
          },
          {
            "name": "sheet_index",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1,
              "title": "Sheet Index"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PreviewResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/spreadsheet/chat/stream": {
      "post": {
        "tags": [
          "spreadsheet"
        ],
        "summary": "Spreadsheet Chat Stream",
        "operationId": "spreadsheet_chat_stream_api_spreadsheet_chat_stream_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SpreadsheetChatRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Body_upload_file_api_files_upload_post": {
        "properties": {
          "file": {
            "type": "string",
            "format": "binary",
            "title": "File"
          }
        },
        "type": "object",
        "required": [
          "file"
        ],
        "title": "Body_upload_file_api_files_upload_post"
      },
      "ClarificationResolution": {
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "column_resolution",
              "sheet_resolution"
            ],
            "title": "Kind",
            "default": "column_resolution"
          },
          "source_field": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Source Field"
          },
          "selected_value": {
            "type": "string",
            "title": "Selected Value"
          }
        },
        "type": "object",
        "required": [
          "selected_value"
        ],
        "title": "ClarificationResolution"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status",
            "default": "ok"
          },
          "service": {
            "type": "string",
            "title": "Service",
            "default": "talk2sheet-api"
          }
        },
        "type": "object",
        "title": "HealthResponse"
      },
      "PreviewResponse": {
        "properties": {
          "file_id": {
            "type": "string",
            "title": "File Id"
          },
          "sheet_index": {
            "type": "integer",
            "title": "Sheet Index"
          },
          "sheet_name": {
            "type": "string",
            "title": "Sheet Name"
          },
          "columns": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Columns"
          },
          "rows": {
            "items": {
              "items": {},
              "type": "array"
            },
            "type": "array",
            "title": "Rows"
          },
          "total_rows": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Total Rows"
          },
          "preview_row_count": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Preview Row Count"
          }
        },
        "type": "object",
        "required": [
          "file_id",
          "sheet_index",
          "sheet_name",
          "columns",
          "rows"
        ],
        "title": "PreviewResponse"
      },
      "SheetDescriptor": {
        "properties": {
          "index": {
            "type": "integer",
            "title": "Index"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "rows": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Rows"
          },
          "columns": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Columns"
          }
        },
        "type": "object",
        "required": [
          "index",
          "name"
        ],
        "title": "SheetDescriptor"
      },
      "SpreadsheetChatRequest": {
        "properties": {
          "file_id": {
            "type": "string",
            "title": "File Id"
          },
          "chat_text": {
            "type": "string",
            "title": "Chat Text"
          },
          "mode": {
            "type": "string",
            "enum": [
              "auto",
              "text",
              "chart"
            ],
            "title": "Mode",
            "default": "auto"
          },
          "sheet_index": {
            "type": "integer",
            "title": "Sheet Index",
            "default": 1
          },
          "sheet_override": {
            "type": "boolean",
            "title": "Sheet Override",
            "default": false
          },
          "locale": {
            "type": "string",
            "title": "Locale",
            "default": "en"
          },
          "conversation_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Conversation Id"
          },
          "clarification_resolution": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ClarificationResolution"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "type": "object",
        "required": [
          "file_id",
          "chat_text"
        ],
        "title": "SpreadsheetChatRequest"
      },
      "UploadedFileResponse": {
        "properties": {
          "file_id": {
            "type": "string",
            "title": "File Id"
          },
          "file_name": {
            "type": "string",
            "title": "File Name"
          },
          "file_type": {
            "type": "string",
            "title": "File Type"
          },
          "sheets": {
            "items": {
              "$ref": "#/components/schemas/SheetDescriptor"
            },
            "type": "array",
            "title": "Sheets"
          }
        },
        "type": "object",
        "required": [
          "file_id",
          "file_name",
          "file_type"
        ],
        "title": "UploadedFileResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}
