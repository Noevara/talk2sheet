        "properties": {
          "file_id": {
            "type": "string",
            "title": "File Id"
          },
          "question": {
            "type": "string",
            "title": "Question"
          },
          "mode": {
            "type": "string",
            "enum": [
              "auto",
              "text",
              "chart"
            ],
            "title": "Mode",
            "default": "auto"
          },
          "sheet_indexes": {
            "items": {
              "type": "integer"
            },
            "type": "array",
            "title": "Sheet Indexes"
          },
          "locale": {
            "type": "string",
            "title": "Locale",
            "default": "en"
          }
        },
        "type": "object",
        "required": [
          "file_id",
          "question"
        ],
        "title": "SpreadsheetBatchRequest"
      },
      "SpreadsheetBatchResponse": {
        "properties": {
          "request_id": {
            "type": "string",
            "title": "Request Id"
          },
          "file_id": {
            "type": "string",
            "title": "File Id"
          },
          "question": {
            "type": "string",
            "title": "Question"
          },
          "mode": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "auto",
                  "text",
                  "chart"
                ]
              },
              {
                "type": "string"
              }
            ],
            "title": "Mode",
            "default": "auto"
          },
          "sheet_indexes": {
            "items": {
              "type": "integer"
            },
            "type": "array",
            "title": "Sheet Indexes"
          },
          "batch_results": {
            "items": {
              "$ref": "#/components/schemas/SpreadsheetBatchResult"
