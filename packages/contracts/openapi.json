        "type": "object",
        "required": [
          "request_id",
          "file_id",
          "question",
          "summary"
        ],
        "title": "SpreadsheetBatchResponse"
      },
      "SpreadsheetBatchResult": {
        "properties": {
          "sheet_index": {
            "type": "integer",
            "title": "Sheet Index"
          },
          "sheet_name": {
            "type": "string",
            "title": "Sheet Name"
          },
          "status": {
            "type": "string",
            "enum": [
              "success",
              "failed"
            ],
            "title": "Status"
          },
          "mode": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "auto",
                  "text",
                  "chart"
                ]
              },
              {
                "type": "string"
              }
            ],
            "title": "Mode",
            "default": "text"
          },
          "answer": {
            "type": "string",
            "title": "Answer",
            "default": ""
          },
          "analysis_text": {
            "type": "string",
            "title": "Analysis Text",
            "default": ""
          },
          "result_row_count": {
            "type": "integer",
            "title": "Result Row Count",
            "default": 0
          },
          "pipeline": {
            "additionalProperties": true,
            "type": "object",
            "title": "Pipeline"
          },
          "execution_disclosure": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ExecutionDisclosure"
              },
              {
                "type": "null"
              }
            ]
          },
          "error": {
            "type": "string",
            "title": "Error",
            "default": ""
          },
          "reason_code": {
            "type": "string",
            "title": "Reason Code",
            "default": ""
          }
        },
        "type": "object",
        "required": [
          "sheet_index",
          "sheet_name",
          "status"
        ],
        "title": "SpreadsheetBatchResult"
      },
      "SpreadsheetBatchSummary": {
        "properties": {
          "total": {
            "type": "integer",
            "title": "Total"
          },
          "succeeded": {
            "type": "integer",
            "title": "Succeeded"
          },
          "failed": {
            "type": "integer",
            "title": "Failed"
          }
        },
        "type": "object",
        "required": [
          "total",
          "succeeded",
          "failed"
        ],
        "title": "SpreadsheetBatchSummary"
      },
      "SpreadsheetChatRequest": {
        "properties": {
          "file_id": {
            "type": "string",
            "title": "File Id"
          },
          "chat_text": {
            "type": "string",
            "title": "Chat Text"
          },
          "mode": {
            "type": "string",
            "enum": [
              "auto",
              "text",
              "chart"
            ],
            "title": "Mode",
            "default": "auto"
          },
          "sheet_index": {
            "type": "integer",
            "title": "Sheet Index",
            "default": 1
          },
          "sheet_override": {
            "type": "boolean",
            "title": "Sheet Override",
            "default": false
          },
          "locale": {
            "type": "string",
            "title": "Locale",
            "default": "en"
          },
          "conversation_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
