      "post": {
        "tags": [
          "spreadsheet"
        ],
        "summary": "Spreadsheet Batch Stream",
        "operationId": "spreadsheet_batch_stream_api_spreadsheet_batch_stream_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SpreadsheetBatchRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
