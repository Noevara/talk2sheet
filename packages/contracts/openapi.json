  "components": {
    "schemas": {
      "Body_upload_file_api_files_upload_post": {
        "properties": {
          "file": {
            "type": "string",
            "format": "binary",
            "title": "File"
          }
        },
        "type": "object",
        "required": [
          "file"
        ],
        "title": "Body_upload_file_api_files_upload_post"
      },
      "ClarificationResolution": {
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "column_resolution",
              "sheet_resolution"
            ],
            "title": "Kind",
            "default": "column_resolution"
          },
          "source_field": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Source Field"
          },
          "selected_value": {
            "type": "string",
            "title": "Selected Value"
          }
        },
        "type": "object",
        "required": [
          "selected_value"
        ],
        "title": "ClarificationResolution"
      },
      "ExecutionDisclosure": {
        "properties": {
          "data_scope": {
            "type": "string",
            "enum": [
              "exact_full_table",
              "sampled_first_n"
            ],
            "title": "Data Scope"
          },
          "exact_used": {
            "type": "boolean",
            "title": "Exact Used"
          },
          "scope_text": {
            "type": "string",
            "title": "Scope Text"
          },
          "scope_warning": {
            "type": "string",
            "title": "Scope Warning",
            "default": ""
          },
          "fallback_reason": {
            "type": "string",
            "title": "Fallback Reason",
            "default": ""
          },
          "fallback_reason_code": {
            "type": "string",
            "title": "Fallback Reason Code",
            "default": ""
          },
          "max_rows": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Max Rows"
          }
        },
        "type": "object",
        "required": [
          "data_scope",
          "exact_used",
          "scope_text"
        ],
        "title": "ExecutionDisclosure"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status",
            "default": "ok"
          },
          "service": {
            "type": "string",
            "title": "Service",
            "default": "talk2sheet-api"
          }
        },
        "type": "object",
        "title": "HealthResponse"
      },
      "PreviewResponse": {
        "properties": {
          "file_id": {
            "type": "string",
            "title": "File Id"
          },
          "sheet_index": {
            "type": "integer",
            "title": "Sheet Index"
          },
          "sheet_name": {
            "type": "string",
            "title": "Sheet Name"
          },
          "columns": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Columns"
          },
          "rows": {
            "items": {
              "items": {},
              "type": "array"
            },
            "type": "array",
            "title": "Rows"
