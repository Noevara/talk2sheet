# Runtime ports
TALK2SHEET_API_PORT=8000
TALK2SHEET_WEB_PORT=8080

# Local storage and API limits
TALK2SHEET_DATA_DIR=/app/data
TALK2SHEET_FILE_STORE_BACKEND=local
TALK2SHEET_MAX_PREVIEW_ROWS=200
TALK2SHEET_MAX_ANALYSIS_ROWS=50000
TALK2SHEET_BATCH_MAX_PARALLEL=1
TALK2SHEET_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

# Provider selection
TALK2SHEET_PLANNER_PROVIDER=auto
TALK2SHEET_CONTEXT_INTERPRETER_PROVIDER=auto
TALK2SHEET_REPAIR_PROVIDER=auto
TALK2SHEET_ANSWER_PROVIDER=rule

# LLM configuration
# TALK2SHEET_LLM_API_KEY is the preferred key for local Docker / backend startup.
# OPENAI_API_KEY is also accepted by the backend as a fallback when TALK2SHEET_LLM_API_KEY is empty.
TALK2SHEET_LLM_API_KEY=
TALK2SHEET_LLM_BASE_URL=
TALK2SHEET_LLM_MODEL=gpt-4.1-mini
TALK2SHEET_LLM_TIMEOUT_SECONDS=30
TALK2SHEET_LLM_MAX_TOKENS=1800
TALK2SHEET_LLM_TEMPERATURE=0
TALK2SHEET_LLM_USE_JSON_SCHEMA=true

# Optional conversation cache tuning
TALK2SHEET_CONVERSATION_MAX_SESSIONS=200
TALK2SHEET_CONVERSATION_MAX_TURNS=6
TALK2SHEET_CONVERSATION_CACHE_TTL_SECONDS=1800
TALK2SHEET_CONVERSATION_CACHE_MAX_ENTRIES=400

# Optional image mirrors for Docker
TALK2SHEET_PYTHON_IMAGE=python:3.11-slim
TALK2SHEET_NODE_IMAGE=node:20-alpine
TALK2SHEET_NGINX_IMAGE=nginx:1.27-alpine
