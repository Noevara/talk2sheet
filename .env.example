TALK2SHEET_API_PORT=8000
TALK2SHEET_WEB_PORT=8080
TALK2SHEET_DATA_DIR=/app/data
TALK2SHEET_MAX_PREVIEW_ROWS=200
TALK2SHEET_MAX_ANALYSIS_ROWS=50000
TALK2SHEET_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
TALK2SHEET_PLANNER_PROVIDER=auto
TALK2SHEET_REPAIR_PROVIDER=auto
TALK2SHEET_ANSWER_PROVIDER=rule
TALK2SHEET_LLM_API_KEY=
TALK2SHEET_LLM_BASE_URL=
TALK2SHEET_LLM_MODEL=gpt-4.1-mini
TALK2SHEET_LLM_TIMEOUT_SECONDS=30
TALK2SHEET_LLM_MAX_TOKENS=1800
TALK2SHEET_LLM_TEMPERATURE=0
TALK2SHEET_LLM_USE_JSON_SCHEMA=true
TALK2SHEET_PYTHON_IMAGE=python:3.11-slim
TALK2SHEET_NODE_IMAGE=node:20-alpine
TALK2SHEET_NGINX_IMAGE=nginx:1.27-alpine
