{
  "name": "talk2sheet-web",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:types": "python ../api/scripts/export_openapi.py && python scripts/generate_api_types.py",
    "check:boundaries": "node scripts/check_feature_boundaries.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "vue-tsc --noEmit",
    "ci": "npm run check:boundaries && npm run lint && npm run typecheck && npm run test && npm run build",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/node": "^22.13.14",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.23.0",
    "eslint-plugin-vue": "^9.33.0",
    "globals": "^15.15.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.27.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.8",
    "vue-eslint-parser": "^10.1.1",
    "vue-tsc": "^2.2.0"
  }
}
