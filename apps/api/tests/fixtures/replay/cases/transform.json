    "local_file": "monthly_region_growth.csv",
    "sheet_index": 1,
    "question": "比较各地区 2025-02 比 2025-01 增长额大于10的地区",
    "selection_plan": {
      "columns": ["Region", "Month", "Amount"],
      "filters": [],
      "distinct_by": null,
      "sort": null,
      "limit": null
    },
    "transform_plan": {
      "derived_columns": [],
      "groupby": ["Region", "Month"],
      "metrics": [
        {"agg": "sum", "col": "Amount", "as_name": "value"}
