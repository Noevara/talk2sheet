        "expected_intent": "ranking",
        "expected_result_columns": ["Service Name", "value"],
        "expected_answer_contains": "220",
        "expected_chart_spec": {
          "type": "bar",
          "x": "Service Name",
          "y": "value",
          "top_k": 5
        }
      },
      {
        "chat_text": "只看前2个",
        "requested_mode": "auto",
        "locale": "zh-CN",
        "expected_mode": "chart",
        "expected_intent": "ranking",
        "expected_result_columns": ["Service Name", "value"],
        "expected_answer_contains": "220",
        "expected_chart_spec": {
          "type": "bar",
          "x": "Service Name",
          "y": "value",
          "top_k": 2
        }
      },
      {
        "chat_text": "上面排第一个的 Compute 是什么东西啊，能结合表格解释一下吗",
        "requested_mode": "auto",
        "locale": "zh-CN",
        "expected_mode": "text",
        "expected_intent": "explain_ranked_item",
        "expected_result_columns": ["Service Name", "Date", "Amount"],
        "expected_answer_contains": "3 条相关明细",
        "expected_preview_rows": [
          ["Compute", "2025-01-03", 120],
          ["Compute", "2025-01-06", 60],
          ["Compute", "2025-02-03", 40]
        ]
      }
    ]
  },
